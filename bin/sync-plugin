#!/bin/bash
# Sync the staged plugin copy under .claude/plugins/kata/ with the repo root.
#
# Usage:
#   bin/sync-plugin           # update the staged copy in place
#   bin/sync-plugin --check   # exit non-zero if the staged copy is out of date
#
# The staged copy lets Claude Code discover the plugin's skills/commands when
# running inside this repo. It is committed to the repo so fresh checkouts work
# without a build step; --check is for CI to keep it in sync with sources.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
STAGE_DIR="$ROOT/.claude/plugins/kata"

# Top-level entries to skip when staging. Anything not in the plugin proper:
# repo metadata (.git), the stage dir itself (.claude — would recurse), CI
# config (.github), dev tooling (bin, Makefile, .prettierrc.yml), and the
# legacy local-dev marketplace (dev, kept for safety even after removal).
SKIP=(.git .claude .github bin dev Makefile .prettierrc.yml)

sync_stage() {
  local dest="$1"
  local find_args=()
  local entry
  for entry in "${SKIP[@]}"; do
    find_args+=(-not -name "$entry")
  done
  rm -rf "$dest"
  mkdir -p "$dest"
  find "$ROOT" -mindepth 1 -maxdepth 1 "${find_args[@]}" \
    -exec cp -a {} "$dest/" \;
}

# Print a deterministic fingerprint of a directory tree: one line per entry,
# tagged by type, including file content hashes and symlink targets. Stable
# under sort so equal trees produce identical output.
fingerprint() {
  local dir="$1"
  (
    cd "$dir"
    find . -mindepth 1 -print0
  ) | LC_ALL=C sort -z | (
    cd "$dir"
    while IFS= read -r -d '' p; do
      if [ -L "$p" ]; then
        printf 'L %s -> %s\n' "$p" "$(readlink "$p")"
      elif [ -d "$p" ]; then
        printf 'D %s\n' "$p"
      elif [ -f "$p" ]; then
        printf 'F %s %s\n' "$p" "$(sha256sum "$p" | awk '{print $1}')"
      else
        printf 'O %s\n' "$p"
      fi
    done
  )
}

case "${1:-}" in
  --check)
    if [ ! -d "$STAGE_DIR" ]; then
      echo "error: $STAGE_DIR does not exist — run bin/sync-plugin to create it." >&2
      exit 1
    fi
    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT
    sync_stage "$tmp/kata"
    if ! diff -u <(fingerprint "$tmp/kata") <(fingerprint "$STAGE_DIR"); then
      echo >&2
      echo "error: $STAGE_DIR is out of sync with repo root." >&2
      echo "Run bin/sync-plugin to update it." >&2
      exit 1
    fi
    echo "$STAGE_DIR is up to date"
    ;;
  "")
    sync_stage "$STAGE_DIR"
    echo "Synced plugin contents to $STAGE_DIR"
    ;;
  -h|--help)
    sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *)
    echo "usage: $0 [--check]" >&2
    exit 2
    ;;
esac
